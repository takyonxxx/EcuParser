<!--
  XDF Definition: Jeep WJ 2.7 CRD - Bosch EDC15C - schema 28F0_100
  Engine:    Mercedes-Benz OM612 DE 27 LA (5-cylinder inline diesel)
  Stock:     163 PS / 400 Nm @ 1800-2400 rpm
  Bin size:  512 KiB (524288 bytes)
  Compatible calibrations: J293_822, J094_704, J409_438

  All 11 main calibration maps are described here. Maps are 16-bit
  little-endian unsigned integers. Physical-unit conversions are
  applied via MATH equations on the Z axis.

  Author:  EcuParser project (cleanroom XDF derived from
           reverse-engineered map addresses, verified against stock
           bins 293-822 / 094-704 / 409-438)
  Format:  TunerPro XDF 1.70
-->
<XDFFORMAT version="1.70">
  <XDFHEADER>
    <flags>0x1</flags>
    <fileversion>1.0</fileversion>
    <deftitle>Jeep WJ 2.7 CRD EDC15C - Schema 28F0_100</deftitle>
    <description>Cleanroom XDF for Bosch EDC15C calibration 28F0_100, used in Jeep Grand Cherokee WJ 2.7 CRD with Mercedes-Benz OM612 engine (163 PS / 400 Nm).</description>
    <author>EcuParser project</author>
    <BASEOFFSET offset="0x0" subtract="0" />
    <DEFAULTS datasizeinbits="16" sigdigits="2" outputtype="1" signed="0" lsbfirst="1" float="0" />
    <REGION type="0xFFFFFFFF" startaddress="0x0" size="0x80000" regioncolor="0x0" regionflags="0x0" name="EDC15C 512KiB Image" desc="Full 512 KiB ECU dump" />
    <CATEGORY index="0x0" name="Injection" />
