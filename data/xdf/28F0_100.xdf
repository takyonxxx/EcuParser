    </XDFAXIS>
  </XDFTABLE>
  <XDFTABLE uniqueid="0x0102" flags="0x30">
    <title>Rail pressure</title>
    <description>Common-rail target pressure map. Raw range 2266..13500 maps to 226..1350 bar via 0.1 scale. Higher rail pressure = finer fuel atomisation = more efficient combustion. CP1 pump safe limit around 1380 bar.</description>
    <CATEGORYMEM index="0" category="1" />
    <XDFAXIS id="x" uniqueid="0x0">
      <EMBEDDEDDATA mmedelementsizebits="16" mmedrowcount="16" mmedcolcount="1" mmedmajorstridebits="0" mmedminorstridebits="0" />
